# ── AI provider (required for card generation, mind maps, explanations) ────────
# Primary: Ollama Cloud (https://ollama.com)
# Fallback backend: OpenRouter (https://openrouter.ai)
#
# Ollama Cloud API key — get yours at https://ollama.com
OLLAMA_CLOUD_API_KEY=6016e45aa07f4b7db71978a1a76b1402.MUQh9I1INzLROiRdpMc-Yjsl
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1

# OpenRouter fallback (optional — used when Ollama Cloud hits limits)
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Per-feature model selection (Ollama Cloud defaults)
# Anki cards (text generation) + AI explanation
AI_TEXT_MODEL=qwen3-coder:480b
# Vision model — visual card detection from PDF page images (multimodal)
AI_VISION_MODEL=qwen3-vl:235b
# QBank — MCQ question generation
AI_QBANK_MODEL=gpt-oss:120b-cloud
# Mind map generation
AI_MINDMAP_MODEL=gpt-oss:120b

# OpenAI-compatible base URL (used by image generation client)
AI_INTEGRATIONS_OPENAI_BASE_URL=https://ollama.com/v1

# ── Database ────────────────────────────────────────────────────────────────────
# Neon cloud (active)
DATABASE_URL=postgresql://neondb_owner:npg_2AkictEo1Vsy@ep-dark-cell-appxlz8t.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── API server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Pro features in local dev ──────────────────────────────────────────────────
# Set to "true" to unlock ALL Pro features locally (QBank, Mind Map, Visual Cards)
# without needing a real Stripe subscription. NEVER set in production.
LOCAL_DEV_IS_PRO=true

# ── Stripe payments (optional — app works fully without it) ───────────────────
# Get test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_51TSzP9A3VfXAVNW4YO4q5xDCCpBiVYXeRdtIJhLj93gws7U1m9xfGW3gaP9Kcn7XyP3Rh9CxnuxYaZKmECRddQdv008imRdlXm
STRIPE_WEBHOOK_SECRET=whsec_EoaxaY7qsuXOicOv9EbEsnL9ioVq2UbM
