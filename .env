# ── AI provider (required for card generation, mind maps, explanations) ────────
# Using local Ollama — make sure Ollama is running on localhost:11434
# Pull both models:
#   ollama pull phi4-mini
#   ollama pull gemma3:4b
OLLAMA_BASE_URL=http://localhost:11434/v1

# Text generation model — decks, cards, QBank, mind maps, AI explanation
AI_TEXT_MODEL=phi4-mini

# Vision generation model — visual card detection from PDF page images
# gemma3:4b is multimodal (text + vision), 3.3 GB
AI_VISION_MODEL=gemma3:4b

# OpenAI-compatible base URL for Ollama
AI_INTEGRATIONS_OPENAI_BASE_URL=http://localhost:11434/v1

# ── Database ────────────────────────────────────────────────────────────────────
# Option A — Docker (recommended for local/Codespaces):
#   docker compose up db -d      ← starts Postgres container
#   then use the URL below
DATABASE_URL=postgres://ankigen:ankigen@localhost:5433/ankigen

# Option B — Neon cloud (free tier, no Docker needed):
#   https://neon.tech → create project → copy the connection string
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── API server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Pro features in local dev ──────────────────────────────────────────────────
# Set to "true" to unlock ALL Pro features locally (QBank, Mind Map, Visual Cards)
# without needing a real Stripe subscription. NEVER set in production.
LOCAL_DEV_IS_PRO=true

# ── Stripe payments (optional — app works fully without it) ───────────────────
# Get test keys at https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# ── App URL (for Stripe redirect URLs) ────────────────────────────────────────
# GitHub Codespaces: auto-detected from CODESPACE_NAME — no action needed
# ngrok or other tunnel:
# APP_URL=https://xxxx.ngrok.io

# ── Frontend proxy ─────────────────────────────────────────────────────────────
# The Vite dev server proxies /api → http://localhost:API_PORT automatically.
# Only change this if you changed PORT above.
# API_PORT=3001
