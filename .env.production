# ══════════════════════════════════════════════════════════════════════════════
# AnkiGen — Production Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# ⚠️  NEVER commit this file to version control
# ⚠️  Replace ALL placeholder values before deploying
# ══════════════════════════════════════════════════════════════════════════════

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=mydomain.com

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=ankigen
POSTGRES_USER=ankigen
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD_64_CHARS_MIN

# ── Required: AI Provider ─────────────────────────────────────────────────────
# At least one AI provider key is required. OpenRouter is the primary.
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional fallback providers:
OLLAMA_CLOUD_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GOOGLE_AI_API_KEY=
MISTRAL_API_KEY=

# ── Model Selection ────────────────────────────────────────────────────────────
AI_TEXT_MODEL=openai/gpt-oss-120b
AI_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
AI_QBANK_MODEL=openai/gpt-oss-120b
AI_MINDMAP_MODEL=openai/gpt-oss-120b
AI_EXPLAIN_MODEL=openai/gpt-oss-120b

# ── Required: Admin Authentication ─────────────────────────────────────────────
# JWT secret for admin token signing. MUST be at least 32 characters.
# Generate: openssl rand -hex 32
ADMIN_JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# Admin login credentials
ADMIN_EMAIL=admin@mydomain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# Admin API key secret (for /api/healthz admin endpoint)
ADMIN_SECRET_KEY=CHANGE_ME_ANOTHER_RANDOM_SECRET

# Optional: IP allowlist for admin access (comma-separated, supports CIDR)
# Example: ADMIN_IP_ALLOWLIST=1.2.3.4,5.6.7.8,192.168.1.0/24
ADMIN_IP_ALLOWLIST=

# ── Encryption Key ────────────────────────────────────────────────────────────
# Used for encrypting provider API keys in the database
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_KEY

# ── Stripe Payments (optional) ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_RETENTION_DAYS=30
