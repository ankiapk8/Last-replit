# ══════════════════════════════════════════════════════════════════════════════
# AnkiGen — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Required: Database ──────────────────────────────────────────────────────
# Render: auto-injected from the managed Postgres database
# Local:  docker compose up db -d  →  postgres://ankigen:ankigen@localhost:5432/ankigen
DATABASE_URL=postgres://ankigen:ankigen@localhost:5432/ankigen

# ── Required: AI Provider ───────────────────────────────────────────────────
# At least one AI provider key is required. OpenRouter is the primary.
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional fallback providers:
# GROQ_API_KEY=gsk_your_groq_key_here
# OLLAMA_CLOUD_API_KEY=your-ollama-cloud-key-here
# OLLAMA_CLOUD_BASE_URL=https://cloud.ollama.com/v1
# GOOGLE_AI_API_KEY=your-google-ai-key
# MISTRAL_API_KEY=your-mistral-key

# ── Required: Admin Authentication ───────────────────────────────────────────
# JWT secret for admin token signing. MUST be at least 32 characters in production.
# Generate: openssl rand -hex 32
ADMIN_JWT_SECRET=change-this-to-a-random-64-char-string-in-production

# Admin API key secret (for /api/healthz admin endpoint)
# Generate: openssl rand -hex 32
ADMIN_SECRET_KEY=change-this-to-another-random-secret

# Encryption key for provider API keys stored in DB
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=change-this-to-a-32-byte-hex-key

# Admin login credentials (used for initial admin user creation)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-strong-password

# Optional: IP allowlist for admin access (comma-separated, supports CIDR)
# ADMIN_IP_ALLOWLIST=1.2.3.4,5.6.7.8

# ── CORS Origins ────────────────────────────────────────────────────────────
# The public frontend and admin frontend URLs (used for CORS whitelisting)
# For Render unified deployment, both point to the same domain:
APP_URL=https://mydomain.com
ADMIN_URL=https://mydomain.com/admin

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Frontend Build ──────────────────────────────────────────────────────────
# Vite dev server port (public frontend)
# VITE_API_URL=http://localhost:3001

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_TO_FILE=true
LOG_RETENTION_DAYS=30

# ── Per-feature Model Selection (optional) ──────────────────────────────────
# AI_TEXT_MODEL=openai/gpt-oss-120b
# AI_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# AI_QBANK_MODEL=openai/gpt-oss-120b
# AI_MINDMAP_MODEL=openai/gpt-oss-120b

# ── Stripe Payments (optional) ──────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# ── Local Dev Pro Features ──────────────────────────────────────────────────
# Set to "true" to unlock ALL Pro features locally without Stripe. NEVER in production.
LOCAL_DEV_IS_PRO=true
