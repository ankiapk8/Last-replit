# ── AI provider (required for card generation, mind maps, explanations) ────────
# Primary: Groq (https://api.groq.com/openai/v1) — ultra-fast inference
# Get a FREE key at https://console.groq.com/keys (no credit card required)
GROQ_API_KEY=gsk_your_groq_key_here

# Fallback: OpenRouter (https://openrouter.ai) — used when Groq hits limits
OPENROUTER_API_KEY=your-openrouter-key-here

# Fallback: Ollama Cloud (https://cloud.ollama.com)
OLLAMA_CLOUD_API_KEY=your-ollama-cloud-key-here
OLLAMA_CLOUD_BASE_URL=https://cloud.ollama.com/v1

# Per-feature model selection (Groq defaults)
# Mind map, text, QBank — openai/gpt-oss-120b (highest reasoning power)
AI_TEXT_MODEL=openai/gpt-oss-120b
# Visual — meta-llama/llama-4-scout-17b-16e-instruct (vision model)
AI_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# QBank — MCQ question generation (same high-reasoning model)
AI_QBANK_MODEL=openai/gpt-oss-120b
# Mind map generation
AI_MINDMAP_MODEL=openai/gpt-oss-120b

# OpenAI-compatible base URL for image generation client
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.groq.com/openai/v1

# ── Database ────────────────────────────────────────────────────────────────────
# Option A — Docker (recommended for local/Codespaces):
#   docker compose up db -d      ← starts Postgres container
#   then use the URL below
DATABASE_URL=postgres://ankigen:ankigen@localhost:5432/ankigen

# Option B — Neon cloud (free tier, no Docker needed):
#   https://neon.tech → create project → copy the connection string
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── API server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Pro features in local dev ──────────────────────────────────────────────────
# Set to "true" to unlock ALL Pro features locally (QBank, Mind Map, Visual Cards)
# without needing a real Stripe subscription. NEVER set in production.
LOCAL_DEV_IS_PRO=true

# ── Stripe payments (optional — app works fully without it) ───────────────────
# Get test keys at https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# ── App URL (for Stripe redirect URLs) ────────────────────────────────────────
# GitHub Codespaces: auto-detected from CODESPACE_NAME — no action needed
# ngrok or other tunnel:
# APP_URL=https://xxxx.ngrok.io

# ── Frontend dev server ───────────────────────────────────────────────────────
# The Vite dev server runs on port 5000 by default.
# It proxies /api → http://localhost:API_PORT automatically.
# API_PORT should match the PORT of the API server (3001 for local dev, 8080 for Docker).
# API_PORT=3001

# Admin secret — required to access /monitor and /test-model endpoints
# Set to a long random string e.g. openssl rand -hex 32
ADMIN_SECRET_KEY=
