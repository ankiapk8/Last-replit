# ── AI provider (required for card generation, mind maps, explanations) ────────
# Primary: qwen3-coder:latest (https://cloud.ollama.com)
# Get your API key at https://cloud.ollama.com
OLLAMA_CLOUD_API_KEY=your-ollama-cloud-key-here
OLLAMA_CLOUD_BASE_URL=https://cloud.ollama.com/v1

# OpenRouter fallback backend (optional — used when qwen3-coder:latest hits limits)
# Get a FREE key at https://openrouter.ai/keys (no credit card required)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Per-feature model selection (Ollama defaults)
# Anki cards (text generation) + AI explanation
AI_TEXT_MODEL=qwen3-coder:480b
# Vision model — visual card detection from PDF page images
AI_VISION_MODEL=llama4:scout
# QBank — MCQ question generation
AI_QBANK_MODEL=gpt-oss:120b
# Mind map generation
AI_MINDMAP_MODEL=deepseek-v4-flash

# OpenAI-compatible base URL for image generation client
AI_INTEGRATIONS_OPENAI_BASE_URL=https://cloud.ollama.com/v1

# ── Database ────────────────────────────────────────────────────────────────────
# Option A — Docker (recommended for local/Codespaces):
#   docker compose up db -d      ← starts Postgres container
#   then use the URL below
DATABASE_URL=postgres://ankigen:ankigen@localhost:5432/ankigen

# Option B — Neon cloud (free tier, no Docker needed):
#   https://neon.tech → create project → copy the connection string
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── API server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Pro features in local dev ──────────────────────────────────────────────────
# Set to "true" to unlock ALL Pro features locally (QBank, Mind Map, Visual Cards)
# without needing a real Stripe subscription. NEVER set in production.
LOCAL_DEV_IS_PRO=true

# ── Stripe payments (optional — app works fully without it) ───────────────────
# Get test keys at https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# ── App URL (for Stripe redirect URLs) ────────────────────────────────────────
# GitHub Codespaces: auto-detected from CODESPACE_NAME — no action needed
# ngrok or other tunnel:
# APP_URL=https://xxxx.ngrok.io

# ── Frontend proxy ─────────────────────────────────────────────────────────────
# The Vite dev server proxies /api → http://localhost:API_PORT automatically.
# Only change this if you changed PORT above.
# API_PORT=3001
